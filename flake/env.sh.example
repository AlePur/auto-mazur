# flake/env.sh — local deployment settings (copy this file to env.sh, fill in
# your values, then source it before running any nix command).
#
# This file is committed as an example template.
# flake/env.sh  is gitignored and should never be committed.
#
# Usage:
#   cp flake/env.sh.example flake/env.sh
#   $EDITOR flake/env.sh
#   source flake/env.sh
#   cd flake && nix flake lock --impure           # first time
#   nixos-rebuild switch --flake ./flake#aws-agent --impure --build-host localhost --target-host root@<EC2-IP>

# Tailscale IP (100.x.y.z) or MagicDNS hostname of the GPU machine.
# vLLM is served on port 8000 (OpenAI-compatible, no authentication needed).
# Verify with: curl http://$MAZUR_GPU_IP:8000/v1/models | jq '.data[].id'
export MAZUR_GPU_IP="100.x.y.z"

# Full model ID as reported by vLLM
export MAZUR_MODEL="LilaRest/gemma-4-31B-it-NVFP4-turbo"

# Context window of the model in tokens (must be >= 100 000)
export MAZUR_CONTEXT_LENGTH="180000"

# Your admin SSH public key (for root login on the EC2 instance)
export MAZUR_SSH_KEY="ssh-rsa AAAA..."
